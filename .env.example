# Base URL for e2e tests and CLI commands
BASE_URL=https://qa.anaconda-sandbox.com

# Optional: Bearer token for API requests
# BEARER_TOKEN=your-token-here

# Anaconda auth API key (CLI and ai commands; fallback: ANACONDA_Auth_TOKEN)
ANACONDA_AUTH_API_KEY=your-api-key-here

# Anaconda AI package channel and version
ANACONDA_AI_CHANNEL=anaconda-cloud/label/dev
ANACONDA_AI_VERSION=0.5.0
